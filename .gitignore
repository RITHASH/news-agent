# --- Python virtual environments ---
.venv/
venv/
env/
ENV/

# --- Python cache / compiled files ---
__pycache__/
*.py[cod]
*$py.class
*.so

# --- Test / type / lint caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# --- IDEs / editors ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- OS cruft ---
.DS_Store
Thumbs.db
desktop.ini

# --- Secrets / credentials / environment ---
.env
.env.*
*.local
# Keep the secret-free template so newcomers know which vars to set.
!.env.example

# --- Logs ---
*.log

# --- Temporary / scratch files ---
*.tmp
*.temp
*.bak
*.swp
*.orig
~$*

# --- Downloaded model weights (re-downloaded at runtime) ---
# Kokoro TTS model + voices
*.onnx
voices-*.bin
kokoro-v1.0.onnx
# Vosk wake-word / STT models (unpacked into ~/.cache/vosk)
vosk-model-*
*.zip

# --- Local caches (Kokoro/Vosk download into the user cache dir) ---
.cache/
.cache/kokoro/
.cache/vosk/

# --- Claude Code local settings (may contain machine-specific config) ---
.claude/settings.local.json

# --- Generated audio ---
*.wav
